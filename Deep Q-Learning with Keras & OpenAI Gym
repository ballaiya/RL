import numpy as np
if not hasattr(np, 'bool8'):
    np.bool8 = np.bool_

import gym

env = gym.make("CartPole-v1")
state_size = env.observation_space.shape[0]
action_size = env.action_space.n

# Initialize weights randomly
weights = np.random.rand(state_size, action_size)

# Hyperparameters
alpha = 0.01
gamma = 0.99
epsilon = 1.0
epsilon_decay = 0.995
min_epsilon = 0.01
num_episodes = 20


def get_q_values(state):
    return np.dot(state, weights)


def select_action(state, epsilon):
    if np.random.rand() < epsilon:
        return env.action_space.sample()
    return np.argmax(get_q_values(state))


for episode in range(num_episodes):
    state, _ = env.reset()
    action = select_action(state, epsilon)
    total_reward = 0
    done = False

    while not done:
        next_state, reward, terminated, truncated, _ = env.step(action)
        done = terminated or truncated

        next_action = select_action(next_state, epsilon) if not done else None

        q_current = get_q_values(state)[action]
        q_next = get_q_values(next_state)[next_action] if not done else 0

        td_target = reward + gamma * q_next
        td_error = td_target - q_current

        weights[:, action] += alpha * td_error * state

        state, action = next_state, next_action
        total_reward += reward

    epsilon = max(min_epsilon, epsilon * epsilon_decay)
    print(f"Episode {episode + 1}, Total Reward: {total_reward}, Epsilon: {epsilon:.2f}")

env.close()
